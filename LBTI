// 核心逻辑
function goHome() {
  showPage('home');
  currentTest = null;
}

function startTest(testKey) {
  currentTest = testData[testKey];
  currentIndex = 0;
  score = { A: 0, B: 0, C: 0, D: 0 };
  selectedOption = null;
  showPage('test-page');
  renderQuestion();
}

function renderQuestion() {
  const questionData = currentTest.q[currentIndex];
  $('prog').innerText = `${currentIndex + 1}/${currentTest.q.length}`;
  $('qtext').innerText = questionData.q;
  $('opts').innerHTML = '';
  selectedOption = null;
  $('nxt').disabled = true;

  // 渲染选项
  questionData.o.forEach(option => {
    const btn = document.createElement('button');
    btn.className = 'option';
    btn.innerText = option.c;
    btn.onclick = () => {
      document.querySelectorAll('.option').forEach(item => item.classList.remove('selected'));
      btn.classList.add('selected');
      selectedOption = option.t;
      $('nxt').disabled = false;
    };
    $('opts').appendChild(btn);
  });
}

// 下一题
$('nxt').onclick = () => {
  score[selectedOption]++;
  currentIndex++;
  if (currentIndex >= currentTest.q.length) {
    showResult();
  } else {
    renderQuestion();
  }
};

// 生成结果
function showResult() {
  let maxType = 'A';
  if (score.B > score[maxType]) maxType = 'B';
  if (score.C > score[maxType]) maxType = 'C';
  if (score.D > score[maxType]) maxType = 'D';

  const result = currentTest.res[maxType];
  $('ravatar').innerHTML = avatarSvg[result.avatar];
  $('rtag').innerText = result.tag;
  $('rtitle').innerText = result.name;
  $('rdesc').innerText = result.desc;
  showPage('res-page');
}

// 重新测试
function restartTest() {
  startTest(currentTest.name);
}

// 复制结果
function copyResult() {
  const text = `${$('rtitle').innerText}\n${$('rdesc').innerText}\n#人格测试 #癫疯测试`;
  navigator.clipboard.writeText(text);
  $('copyTips').style.display = 'block';
  setTimeout(() => $('copyTips').style.display = 'none', 1500);
}

